<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp" app:cardElevation="1dp"
    app:cardBackgroundColor="@color/white">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="14dp"
        android:gravity="center_vertical">
        <!-- Avatar circle -->
        <TextView android:id="@+id/tvAvatarInitial"
            android:layout_width="42dp" android:layout_height="42dp"
            android:gravity="center" android:textSize="16sp"
            android:textStyle="bold" android:textColor="@color/white"
            android:background="+@drawable/bg_circle_teal"
            android:layout_marginEnd="12dp"/>
        <!-- Name + Email -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:id="@+id/tvMemberName"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="13sp" android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginEnd="6dp"/>
                <TextView android:id="@+id/tvAdminBadge"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/admin_label"
                    android:textSize="9sp" android:textStyle="bold"
                    android:textColor="@color/teal_dark"
                    android:background="+@drawable/member_chip_paid"
                    android:paddingHorizontal="6dp" android:paddingVertical="2dp"
                    android:visibility="gone"/>
            </LinearLayout>
            <TextView android:id="@+id/tvMemberEmail"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="11sp" android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
        <!-- Balance -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="end">
            <TextView android:id="@+id/tvBalance"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="13sp" android:textStyle="bold"
                android:textColor="@color/green_success"/>
            <TextView android:id="@+id/tvBalanceLabel"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="9sp" android:textColor="@color/text_secondary"
                android:gravity="end" android:layout_marginTop="1dp"/>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
