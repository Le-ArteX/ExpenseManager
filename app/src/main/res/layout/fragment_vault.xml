<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_surface">
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        app:elevation="0dp">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent" android:layout_height="?attr/actionBarSize"
            android:background="@color/teal_dark"
            app:title="@string/warranty_vault"
            app:titleTextColor="@color/white"/>
    </com.google.android.material.appbar.AppBarLayout>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvVaultItems"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:clipToPadding="false"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"/>
    <LinearLayout android:id="@+id/emptyVaultState"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" android:gravity="center"
        android:visibility="gone"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="■" android:textSize="48sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Warranty Vault is empty"
            android:textSize="16sp" android:textStyle="bold"
            android:textColor="@color/text_secondary" android:layout_marginTop="12dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Add shared electronics and snap receipts"
            android:textSize="12sp" android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp"/>
    </LinearLayout>
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAddVaultItem"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="bottom|end" android:layout_margin="20dp"
        android:text="@string/add_item"
        app:icon="@drawable/ic_add"
        app:backgroundTint="@color/teal_dark"
        android:textColor="@color/white"/>
</androidx.coordinatorlayout.widget.CoordinatorLayout>