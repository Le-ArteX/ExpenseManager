<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardVault"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp" app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="14dp"
        android:gravity="center_vertical">
        <!-- Item Icon / Thumbnail -->
        <TextView android:id="@+id/tvItemIcon"
            android:layout_width="52dp" android:layout_height="52dp"
            android:text="■" android:textSize="26sp"
            android:gravity="center"
            android:background="+@drawable/bg_circle_teal"
            android:layout_marginEnd="12dp"/>
        <!-- Info -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/tvItemName"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
            <TextView android:id="@+id/tvBrand"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="11sp" android:textColor="@color/text_secondary"
                android:layout_marginTop="1dp"/>
            <TextView android:id="@+id/tvWarrantyStatus"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="10sp" android:textStyle="bold"
                android:layout_marginTop="5dp"
                android:paddingHorizontal="8dp" android:paddingVertical="3dp"
                android:background="+@drawable/member_chip_paid"/>
            <TextView android:id="@+id/tvReceiptCount"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="10sp" android:textColor="@color/teal_primary"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
        <!-- Price + View -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="end">
            <TextView android:id="@+id/tvPrice"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="13sp" android:textStyle="bold" android:textColor="@color/text_secondary"/>
            <TextView android:id="@+id/tvViewReceipt"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="View" android:textSize="11sp"
                android:textColor="@color/teal_primary"
                android:layout_marginTop="4dp"
                android:padding="4dp"/>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>